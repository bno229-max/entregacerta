rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function myRole() { return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role; }
    function isAdmin() { return signedIn() && myRole() == 'admin'; }
    function isMotorista() { return signedIn() && myRole() == 'motorista'; }

    // Perfil do usuário logado (admin ou motorista)
    match /usuarios/{uid} {
      allow read:   if signedIn() && (request.auth.uid == uid || isAdmin());
      allow create: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow update: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow delete: if isAdmin();
    }

    // Cadastro de motoristas (dados administrativos: CPF, veículo, etc.)
    // O login do motorista é criado pelo admin (via app secundário do Firebase no painel),
    // por isso só o admin escreve aqui.
    match /motoristas/{id} {
      allow read:  if isAdmin() || isMotorista();
      allow write: if isAdmin();
    }

    // Cadastro de clientes
    match /clientes/{id} {
      allow read:  if isAdmin() || isMotorista();
      allow write: if isAdmin();
    }

    // Entregas: admin vê e edita tudo; motorista só vê/edita as suas
    match /entregas/{id} {
      allow read:   if isAdmin() || (isMotorista() && resource.data.motoristaId == request.auth.uid);
      allow create: if isAdmin();
      allow update: if isAdmin() || (isMotorista() && resource.data.motoristaId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // Configurações do tenant (nome, logo, cnpj...)
    match /config/{id} {
      allow read:  if signedIn();
      allow write: if isAdmin();
    }

    // Logs de auditoria: qualquer usuário logado pode criar, só admin lê
    match /logs/{id} {
      allow read:            if isAdmin();
      allow create:          if signedIn();
      allow update, delete:  if false;
    }
  }
}
